{
  "name": "fastwayshare",
  "version": "1.0.0",
  "private": true,
  "description": "Peer-to-peer encrypted file transfer using WebRTC — no server storage, end-to-end encrypted.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build:client": "npm run build --workspace=client",
    "deploy:server": "npm run deploy --workspace=server"
  },
  "keywords": ["webrtc", "p2p", "file-transfer", "encrypted", "cloudflare-workers"],
  "license": "MIT"
}
